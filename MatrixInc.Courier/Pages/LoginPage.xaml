<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MatrixInc.Courier.Pages.LoginPage"
             BackgroundColor="#667eea">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <!-- Logo/Icon -->
            <Frame BackgroundColor="White" 
                   CornerRadius="60" 
                   WidthRequest="120" 
                   HeightRequest="120"
                   HorizontalOptions="Center"
                   HasShadow="True"
                   Padding="0">
                <Label Text="📦" 
                       FontSize="60" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"/>
            </Frame>

            <!-- Title -->
            <Label Text="Matrix Inc Courier" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>

            <Label Text="Bezorg App" 
                   FontSize="16" 
                   TextColor="#E0E0E0"
                   HorizontalOptions="Center"
                   Margin="0,-10,0,20"/>

            <!-- Login Card -->
            <Frame BackgroundColor="White" 
                   CornerRadius="15" 
                   HasShadow="True"
                   Padding="25">
                <VerticalStackLayout Spacing="15">

                    <!-- Info Banner -->
                    <Frame BackgroundColor="#FFF9E6" 
                           CornerRadius="8" 
                           Padding="12"
                           HasShadow="False"
                           BorderColor="#FFD700">
                        <Label TextColor="#856404">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="ℹ️ " FontSize="14"/>
                                    <Span Text="Gesimuleerd login systeem" FontAttributes="Bold" FontSize="14"/>
                                    <Span Text="&#x0a;Voer willekeurige gegevens in om in te loggen." FontSize="12"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Frame>

                    <!-- Username -->
                    <Label Text="Gebruikersnaam" 
                           TextColor="#333" 
                           FontAttributes="Bold"/>
                    <Frame BorderColor="#DDD" 
                           CornerRadius="8" 
                           Padding="0" 
                           HasShadow="False">
                        <Entry x:Name="UsernameEntry"
                               Placeholder="courier123"
                               PlaceholderColor="#999"
                               TextColor="#333"/>
                    </Frame>

                    <!-- Password -->
                    <Label Text="Wachtwoord" 
                           TextColor="#333" 
                           FontAttributes="Bold"/>
                    <Frame BorderColor="#DDD" 
                           CornerRadius="8" 
                           Padding="0" 
                           HasShadow="False">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="••••••••"
                               IsPassword="True"
                               PlaceholderColor="#999"
                               TextColor="#333"/>
                    </Frame>

                    <!-- Van Number -->
                    <Label Text="Busjesnummer" 
                           TextColor="#333" 
                           FontAttributes="Bold"/>
                    <Frame BorderColor="#DDD" 
                           CornerRadius="8" 
                           Padding="0" 
                           HasShadow="False">
                        <Entry x:Name="VanNumberEntry"
                               Placeholder="bijv. BUS-001"
                               PlaceholderColor="#999"
                               TextColor="#333"
                               Keyboard="Text"/>
                    </Frame>

                    <!-- Login Button -->
                    <Button x:Name="LoginButton"
                            Text="Inloggen"
                            BackgroundColor="#667eea"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="50"
                            Margin="0,10,0,0"
                            Clicked="OnLoginClicked"/>

                    <!-- Forgot Password -->
                    <Button Text="Wachtwoord vergeten?"
                            BackgroundColor="Transparent"
                            TextColor="#667eea"
                            FontSize="14"
                            Clicked="OnForgotPasswordClicked"/>

                </VerticalStackLayout>
            </Frame>

            <!-- Test Login Button -->
            <Frame BackgroundColor="#E8F5E9" 
                   CornerRadius="10" 
                   Padding="15"
                   HasShadow="False"
                   BorderColor="#4CAF50">
                <VerticalStackLayout Spacing="10">
                    <Label Text="⚡ Test functie" 
                           FontAttributes="Bold"
                           TextColor="#2E7D32"
                           FontSize="12"/>
                    <Button Text="Snel inloggen als Courier (BUS-001)"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            FontSize="14"
                            CornerRadius="6"
                            HeightRequest="40"
                            Clicked="OnTestLoginClicked"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Footer -->
            <Label Text="🔒 Beveiligde verbinding" 
                   FontSize="12" 
                   TextColor="White"
                   Opacity="0.7"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
