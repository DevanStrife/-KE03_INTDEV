<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MatrixInc.Courier.Models"
             x:Class="MatrixInc.Courier.Pages.OrdersPage"
             Title="Matrix Inc - Courier">

    <Grid RowDefinitions="Auto,*" Padding="10">

        <!-- Header met filter en refresh -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,10">
            <Label Text="📦 Te Leveren Bestellingen" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   VerticalOptions="Center"/>

            <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center" Margin="0,0,10,0">
                <Label Text="Alleen Te Leveren" VerticalOptions="Center"/>
                <Switch IsToggled="True" Toggled="OnFilterToggled"/>
            </HorizontalStackLayout>

            <Button Grid.Column="2" 
                    Text="🔄" 
                    Clicked="OnRefreshClicked"
                    WidthRequest="50"
                    HeightRequest="50"/>
        </Grid>

        <!-- Loading Indicator -->
        <ActivityIndicator x:Name="LoadingIndicator"
                          Grid.Row="1"
                          IsRunning="False"
                          IsVisible="False"
                          Color="#2196F3"
                          HeightRequest="50"
                          WidthRequest="50"
                          VerticalOptions="Center"
                          HorizontalOptions="Center"/>

        <!-- Orders List -->
        <CollectionView x:Name="OrdersCollectionView" 
                       Grid.Row="1"
                       SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:DeliveryOrder">
                    <Frame Margin="0,0,0,10" 
                           Padding="15"
                           CornerRadius="10"
                           HasShadow="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOrderTapped" 
                                                CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                            <!-- Order nummer en status -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding OrderId, StringFormat='Order #{0}'}"
                                   FontSize="18"
                                   FontAttributes="Bold"/>

                            <Frame Grid.Row="0" Grid.Column="1"
                                   BackgroundColor="{Binding StatusColor}"
                                   Padding="8,4"
                                   CornerRadius="5"
                                   HasShadow="False">
                                <Label Text="{Binding Status}"
                                       TextColor="White"
                                       FontSize="12"
                                       FontAttributes="Bold"/>
                            </Frame>

                            <!-- Klant info -->
                            <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                <Label FontSize="16" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="👤 " FontSize="16"/>
                                            <Span Text="{Binding CustomerName}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label FontSize="14" TextColor="Gray" Margin="0,5,0,0">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="📍 " FontSize="14"/>
                                            <Span Text="{Binding CustomerAddress}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label FontSize="14" TextColor="Gray" Margin="0,5,0,0">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="📞 " FontSize="14"/>
                                            <Span Text="{Binding CustomerPhone}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>

                            <!-- Order details -->
                            <Grid Grid.Row="2" Grid.ColumnSpan="2" 
                                  ColumnDefinitions="*,*,*" 
                                  Margin="0,10,0,0">

                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="📦 Items" FontSize="12" TextColor="Gray"/>
                                    <Label Text="{Binding ItemCount}" 
                                           FontSize="16" 
                                           FontAttributes="Bold"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="💰 Totaal" FontSize="12" TextColor="Gray"/>
                                    <Label Text="{Binding TotalAmount, StringFormat='€{0:F2}'}" 
                                           FontSize="16" 
                                           FontAttributes="Bold"
                                           TextColor="Green"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2">
                                    <Label Text="📅 Datum" FontSize="12" TextColor="Gray"/>
                                    <Label Text="{Binding OrderDate, StringFormat='{0:dd-MM}'}" 
                                           FontSize="16" 
                                           FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Tap instructie -->
                            <Label Grid.Row="3" Grid.ColumnSpan="2"
                                   Text="👆 Tik voor acties"
                                   FontSize="12"
                                   TextColor="#2196F3"
                                   HorizontalOptions="Center"
                                   Margin="0,10,0,0"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="📭" FontSize="60" HorizontalOptions="Center"/>
                    <Label Text="Geen bestellingen gevonden" 
                           FontSize="18" 
                           TextColor="Gray"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
