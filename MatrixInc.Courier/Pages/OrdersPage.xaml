<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MatrixInc.Courier.Models"
             x:Class="MatrixInc.Courier.Pages.OrdersPage"
             Title="Matrix Inc - Courier">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="10">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,0,0,10">
            <Label Grid.Column="0" Grid.Row="0"
                   Text="📦 Bestellingen" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="#333"
                   VerticalOptions="Center"/>

            <!-- Van Number Display -->
            <Frame Grid.Column="0" Grid.Row="1" 
                   Grid.ColumnSpan="2"
                   BackgroundColor="#E3F2FD" 
                   CornerRadius="8" 
                   Padding="10,5"
                   HasShadow="False"
                   Margin="0,5,0,0">
                <Label x:Name="VanNumberLabel"
                       Text="🚚 Busje: BUS-001"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#1976D2"/>
            </Frame>

            <Button Grid.Column="1" Grid.Row="0"
                    Text="🔄" 
                    Clicked="OnRefreshClicked"
                    WidthRequest="50"
                    HeightRequest="50"/>

            <Button Grid.Column="2" Grid.Row="0"
                    Text="🚪"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#F44336"
                    TextColor="White"
                    WidthRequest="50"
                    HeightRequest="50"/>
        </Grid>

        <!-- Route Status Banner -->
        <Frame x:Name="RouteStatusBanner"
               Grid.Row="1"
               BackgroundColor="#4CAF50"
               CornerRadius="10"
               Padding="15"
               Margin="0,0,0,10"
               IsVisible="False"
               HasShadow="True">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="5">
                    <Label Text="🚗 Route Actief"
                           TextColor="White"
                           FontSize="16"
                           FontAttributes="Bold"/>
                    <Label x:Name="RouteStatusLabel"
                           Text="Onderweg naar Jan Jansen • Nog 3 pakjes"
                           TextColor="White"
                           FontSize="14"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        x:Name="CancelRouteButton"
                        Text="❌"
                        WidthRequest="45"
                        HeightRequest="45"
                        CornerRadius="22"
                        BackgroundColor="#FF5722"
                        TextColor="White"
                        FontSize="20"
                        Clicked="OnCancelRouteClicked"
                        VerticalOptions="Center"/>
            </Grid>
        </Frame>

        <!-- Mode Toggle -->
        <Frame Grid.Row="2"
               x:Name="ModeToggleFrame"
               BackgroundColor="#FFF9E6"
               CornerRadius="10"
               Padding="10"
               Margin="0,0,0,10"
               HasShadow="False"
               HeightRequest="50"
               IsVisible="True">
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="📦 Beschikbare Orders"
                       TextColor="#856404"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
                <Switch x:Name="ModeSwitch"
                        IsToggled="False"
                        Toggled="OnModeSwitchToggled"
                        OnColor="#4CAF50"
                        VerticalOptions="Center"/>
                <Label Text="🚗 Actieve Route"
                       TextColor="#856404"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Frame>

        <!-- Content Area (Orders List) -->
        <Grid Grid.Row="3">
            <!-- Loading Indicator -->
            <ActivityIndicator x:Name="LoadingIndicator"
                              IsRunning="False"
                              IsVisible="False"
                              Color="#2196F3"
                              HeightRequest="50"
                              WidthRequest="50"
                              VerticalOptions="Center"
                              HorizontalOptions="Center"
                              ZIndex="10"/>

            <!-- Orders List -->
            <CollectionView x:Name="OrdersCollectionView" 
                           SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:DeliveryOrder">
                        <Frame Margin="0,0,0,10" 
                               Padding="15"
                               CornerRadius="10"
                               HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOrderTapped" 
                                                    CommandParameter="{Binding .}"/>
                            </Frame.GestureRecognizers>

                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto">

                                <!-- Checkbox voor selectie (alleen in pickup mode) -->
                                <CheckBox Grid.Row="0" Grid.Column="0"
                                         Grid.RowSpan="2"
                                         IsChecked="{Binding IsSelected}"
                                         Color="#667eea"
                                         VerticalOptions="Center"
                                         Margin="0,0,10,0"
                                         CheckedChanged="OnOrderSelectionChanged"/>

                                <!-- Order nummer -->
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding OrderId, StringFormat='Order #{0}'}"
                                       FontSize="18"
                                       FontAttributes="Bold"/>

                                <!-- Status -->
                                <Frame Grid.Row="0" Grid.Column="2"
                                       BackgroundColor="{Binding StatusColor}"
                                       Padding="8,4"
                                       CornerRadius="5"
                                       HasShadow="False">
                                    <Label Text="{Binding Status}"
                                           TextColor="White"
                                           FontSize="12"
                                           FontAttributes="Bold"/>
                                </Frame>

                                <!-- Klant info -->
                                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                    <Label FontSize="16" FontAttributes="Bold" TextColor="#333">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="👤 " FontSize="16"/>
                                                <Span Text="{Binding CustomerName}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <Label FontSize="14" TextColor="#666" Margin="0,5,0,0" LineBreakMode="TailTruncation">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="📍 " FontSize="14"/>
                                                <Span Text="{Binding CustomerAddress}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>

                                <!-- Order details -->
                                <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" 
                                      ColumnDefinitions="*,*" 
                                      Margin="0,10,0,0">
                                    <Label Grid.Column="0" TextColor="#666" FontSize="14">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="📦 " FontSize="14"/>
                                                <Span Text="{Binding ItemCount, StringFormat='{0} items'}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <Label Grid.Column="1" TextColor="#666" FontSize="14" HorizontalOptions="End">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="💶 € " FontSize="14"/>
                                                <Span Text="{Binding TotalAmount, StringFormat='{0:F2}'}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Grid>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Bottom Action Bar -->
        <Frame Grid.Row="4"
               x:Name="BottomActionBar"
               BackgroundColor="#667eea"
               CornerRadius="15"
               Padding="15"
               Margin="0,10,0,0"
               HasShadow="True"
               IsVisible="False">
            <Grid ColumnDefinitions="*,Auto">
                <Label x:Name="SelectionCountLabel"
                       Grid.Column="0"
                       Text="0 orders geselecteerd"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        x:Name="StartRouteButton"
                        Text="🚗 Start Route"
                        BackgroundColor="White"
                        TextColor="#667eea"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        Padding="20,10"
                        Clicked="OnStartRouteClicked"/>
            </Grid>
        </Frame>

    </Grid>

</ContentPage>
