@page
@model MatrixInc.Admin.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Productbeheer";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-box-seam"></i> Productbeheer</h1>
    <a asp-page="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nieuw Product
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filters -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="bi bi-funnel"></i> Filters</h5>
    </div>
    <div class="card-body">
        <form method="get">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="SearchTerm" class="form-label">Zoeken</label>
                    <input asp-for="SearchTerm" class="form-control" placeholder="Naam of beschrijving..." />
                </div>
                <div class="col-md-3">
                    <label asp-for="CategoryFilter" class="form-label">Categorie</label>
                    <select asp-for="CategoryFilter" class="form-select">
                        <option value="">Alle categorieën</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="StockFilter" class="form-label">Voorraad</label>
                    <select asp-for="StockFilter" class="form-select">
                        <option value="">Alle voorraadniveaus</option>
                        <option value="in_stock">Op voorraad (>10)</option>
                        <option value="low_stock">Lage voorraad (1-10)</option>
                        <option value="out_of_stock">Uitverkocht (0)</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="StatusFilter" class="form-label">Status</label>
                    <select asp-for="StatusFilter" class="form-select">
                        <option value="">Alle statussen</option>
                        <option value="active">Actief</option>
                        <option value="inactive">Inactief</option>
                    </select>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Zoeken
                    </button>
                    <a asp-page="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Reset Filters
                    </a>
                    <span class="text-muted ms-3">
                        <strong>@Model.Products.Count()</strong> product(en) gevonden
                    </span>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Naam</th>
                        <th>Categorie</th>
                        <th>Prijs</th>
                        <th>Voorraad</th>
                        <th>Status</th>
                        <th>Acties</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td>@product.Id</td>
                            <td><strong>@product.Name</strong></td>
                            <td>@product.Category</td>
                            <td>€@product.Price.ToString("F2")</td>
                            <td>
                                @if (product.StockQuantity > 10)
                                {
                                    <span class="badge bg-success">@product.StockQuantity</span>
                                }
                                else if (product.StockQuantity > 0)
                                {
                                    <span class="badge bg-warning">@product.StockQuantity</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@product.StockQuantity</span>
                                }
                            </td>
                            <td>
                                @if (product.IsActive)
                                {
                                    <span class="badge bg-success">Actief</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactief</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-page="Edit" asp-route-id="@product.Id" class="btn btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Bewerk
                                    </a>
                                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal@(product.Id)">
                                        <i class="bi bi-trash"></i> Verwijder
                                    </button>
                                </div>

                                <!-- Delete Modal -->
                                <div class="modal fade" id="deleteModal@(product.Id)" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Product verwijderen</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                Weet u zeker dat u <strong>@product.Name</strong> wilt verwijderen?
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                                    <input type="hidden" name="id" value="@product.Id" />
                                                    <button type="submit" class="btn btn-danger">Verwijderen</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Products.Any())
            {
                <div class="alert alert-info text-center mb-0">
                    <i class="bi bi-info-circle"></i> Geen producten gevonden met de huidige filters.
                </div>
            }
        </div>
    </div>
</div>
