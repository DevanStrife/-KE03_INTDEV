@page
@model MatrixInc.Admin.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Bestellingen Beheer";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-cart-check-fill"></i> Bestellingen Beheer</h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Section -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Status Filter</label>
                    <select name="statusFilter" class="form-select" onchange="this.form.submit()">
                        <option value="">Alle Statussen</option>
                        <option value="In Bewerking" selected="@(Model.StatusFilter == "In Bewerking")">In Bewerking</option>
                        <option value="Klaar aan het Maken" selected="@(Model.StatusFilter == "Klaar aan het Maken")">Klaar aan het Maken</option>
                        <option value="Klaar voor Levering" selected="@(Model.StatusFilter == "Klaar voor Levering")">Klaar voor Levering</option>
                        <option value="Onderweg" selected="@(Model.StatusFilter == "Onderweg")">Onderweg</option>
                        <option value="Afgeleverd" selected="@(Model.StatusFilter == "Afgeleverd")">Afgeleverd</option>
                        <option value="Geannuleerd" selected="@(Model.StatusFilter == "Geannuleerd")">Geannuleerd</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Zoek op Klant</label>
                    <input type="text" name="customerSearch" class="form-control" placeholder="Naam of email..." value="@Model.CustomerSearch" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Sorteer op</label>
                    <select name="sortBy" class="form-select" onchange="this.form.submit()">
                        <option value="date_desc" selected="@(Model.SortBy == "date_desc")">Nieuwste eerst</option>
                        <option value="date_asc" selected="@(Model.SortBy == "date_asc")">Oudste eerst</option>
                        <option value="amount_desc" selected="@(Model.SortBy == "amount_desc")">Hoogste bedrag</option>
                        <option value="amount_asc" selected="@(Model.SortBy == "amount_asc")">Laagste bedrag</option>
                    </select>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel"></i> Filter Toepassen
                    </button>
                    <a asp-page="./Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Reset Filters
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Orders.Any())
    {
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Totaal Bestellingen</h6>
                        <h3 class="mb-0 text-primary">@Model.Orders.Count()</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">In Bewerking</h6>
                        <h3 class="mb-0 text-warning">@Model.Orders.Count(o => o.Status == "In Bewerking")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Klaar voor Levering</h6>
                        <h3 class="mb-0 text-info">@Model.Orders.Count(o => o.Status == "Klaar voor Levering")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-2">Totale Omzet</h6>
                        <h3 class="mb-0 text-success">€@Model.Orders.Sum(o => o.TotalAmount).ToString("F2")</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Order ID</th>
                                <th>Klant</th>
                                <th>Datum</th>
                                <th>Status</th>
                                <th>Items</th>
                                <th>Totaal</th>
                                <th>Acties</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders)
                            {
                                <tr>
                                    <td><strong>#@order.Id</strong></td>
                                    <td>
                                        @if (order.Customer != null)
                                        {
                                            <div>
                                                <strong>@order.Customer.Name</strong><br />
                                                <small class="text-muted">@order.Customer.Email</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Onbekend</span>
                                        }
                                    </td>
                                    <td>
                                        @order.OrderDate.ToString("dd-MM-yyyy")<br />
                                        <small class="text-muted">@order.OrderDate.ToString("HH:mm")</small>
                                    </td>
                                    <td>
                                        @if (order.Status == "In behandeling")
                                        {
                                            <span class="badge bg-warning text-dark">@order.Status</span>
                                        }
                                        else if (order.Status == "Verzonden")
                                        {
                                            <span class="badge bg-info">@order.Status</span>
                                        }
                                        else if (order.Status == "Afgeleverd")
                                        {
                                            <span class="badge bg-success">@order.Status</span>
                                        }
                                        else if (order.Status == "Geannuleerd")
                                        {
                                            <span class="badge bg-danger">@order.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@order.Status</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@order.OrderItems.Sum(oi => oi.Quantity)</span> items
                                    </td>
                                    <td>
                                        <strong class="text-success">€@order.TotalAmount.ToString("F2")</strong>
                                    </td>
                                    <td>
                                        <a asp-page="/Orders/Details" asp-route-id="@order.Id" 
                                           class="btn btn-sm btn-info" title="Bekijk details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Nog geen bestellingen in het systeem.
        </div>
    }
</div>
