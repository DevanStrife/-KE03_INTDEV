@page
@model IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

@{
    var adminUser = HttpContext.Session.GetString("AdminUser");
    var adminRole = HttpContext.Session.GetString("AdminRole");
}

@if (!string.IsNullOrEmpty(adminUser))
{
    <div class="alert alert-info alert-dismissible fade show mb-4">
        <i class="bi bi-person-badge"></i> <strong>Welkom, @adminUser!</strong> U bent ingelogd als @adminRole.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="text-center mb-5">
    <h1 class="display-4">
        <i class="bi bi-speedometer2"></i> Admin Dashboard
    </h1>
    <p class="lead">Matrix Inc Beheerportaal</p>
</div>

<div class="row">
    <div class="col-md-3 mb-4">
        <div class="card shadow-sm h-100 border-primary">
            <div class="card-body text-center">
                <i class="bi bi-box-seam text-primary" style="font-size: 3rem;"></i>
                <h3 class="mt-3">@Model.TotalProducts</h3>
                <p class="text-muted mb-3">Totaal Producten</p>
                <a asp-page="/Products/Index" class="btn btn-primary btn-sm">
                    <i class="bi bi-arrow-right"></i> Beheer Producten
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4">
        <div class="card shadow-sm h-100 border-success">
            <div class="card-body text-center">
                <i class="bi bi-receipt text-success" style="font-size: 3rem;"></i>
                <h3 class="mt-3">@Model.TotalOrders</h3>
                <p class="text-muted mb-3">Totaal Bestellingen</p>
                <a asp-page="/Orders/Index" class="btn btn-success btn-sm">
                    <i class="bi bi-arrow-right"></i> Bekijk Bestellingen
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4">
        <div class="card shadow-sm h-100 border-info">
            <div class="card-body text-center">
                <i class="bi bi-people text-info" style="font-size: 3rem;"></i>
                <h3 class="mt-3">@Model.TotalCustomers</h3>
                <p class="text-muted mb-3">Totaal Klanten</p>
                <a asp-page="/Customers/Index" class="btn btn-info btn-sm">
                    <i class="bi bi-arrow-right"></i> Bekijk Klanten
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4">
        <div class="card shadow-sm h-100 border-warning">
            <div class="card-body text-center">
                <i class="bi bi-currency-euro text-warning" style="font-size: 3rem;"></i>
                <h3 class="mt-3">€@Model.TotalRevenue.ToString("F2")</h3>
                <p class="text-muted mb-3">Totale Omzet</p>
                <a asp-page="/Orders/Index" class="btn btn-warning btn-sm">
                    <i class="bi bi-graph-up"></i> Bekijk Omzet
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recente Bestellingen</h5>
            </div>
            <div class="card-body">
                @if (Model.RecentOrders.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Order ID</th>
                                    <th>Klant</th>
                                    <th>Email</th>
                                    <th>Datum</th>
                                    <th>Items</th>
                                    <th>Bedrag</th>
                                    <th>Status</th>
                                    <th>Acties</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td><strong>#@order.Id</strong></td>
                                        <td>@order.Customer?.Name</td>
                                        <td>
                                            <small class="text-muted">@order.Customer?.Email</small>
                                        </td>
                                        <td>
                                            @order.OrderDate.ToString("dd-MM-yyyy")<br />
                                            <small class="text-muted">@order.OrderDate.ToString("HH:mm")</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary">@order.OrderItems.Sum(oi => oi.Quantity)</span>
                                        </td>
                                        <td><strong class="text-success">€@order.TotalAmount.ToString("F2")</strong></td>
                                        <td>
                                            @if (order.Status == "In behandeling")
                                            {
                                                <span class="badge bg-warning text-dark">@order.Status</span>
                                            }
                                            else if (order.Status == "Verzonden")
                                            {
                                                <span class="badge bg-info">@order.Status</span>
                                            }
                                            else if (order.Status == "Afgeleverd")
                                            {
                                                <span class="badge bg-success">@order.Status</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@order.Status</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-page="/Orders/Details" asp-route-id="@order.Id" 
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-3 text-center">
                        <a asp-page="/Orders/Index" class="btn btn-outline-dark">
                            <i class="bi bi-list-ul"></i> Bekijk alle bestellingen
                        </a>
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle"></i> Nog geen bestellingen geplaatst.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
