@page
@model IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="text-center mb-5">
    <h1 class="display-4">
        <i class="bi bi-speedometer2"></i> Admin Dashboard
    </h1>
    <p class="lead">Matrix Inc Beheerportaal</p>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <i class="bi bi-box-seam text-primary" style="font-size: 3rem;"></i>
                <h3 class="mt-3">@Model.TotalProducts</h3>
                <p class="text-muted">Totaal Producten</p>
                <a asp-page="/Products/Index" class="btn btn-primary">Beheer Producten</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <i class="bi bi-receipt text-success" style="font-size: 3rem;"></i>
                <h3 class="mt-3">@Model.TotalOrders</h3>
                <p class="text-muted">Totaal Bestellingen</p>
                <a asp-page="/Orders/Index" class="btn btn-success">Bekijk Bestellingen</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <i class="bi bi-people text-info" style="font-size: 3rem;"></i>
                <h3 class="mt-3">@Model.TotalCustomers</h3>
                <p class="text-muted">Totaal Klanten</p>
                <a asp-page="/Customers/Index" class="btn btn-info">Bekijk Klanten</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recente Bestellingen</h5>
            </div>
            <div class="card-body">
                @if (Model.RecentOrders.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Bestelnr.</th>
                                    <th>Klant</th>
                                    <th>Datum</th>
                                    <th>Bedrag</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td>#@order.Id</td>
                                        <td>@order.Customer.Name</td>
                                        <td>@order.OrderDate.ToString("dd-MM-yyyy HH:mm")</td>
                                        <td>€@order.TotalAmount.ToString("F2")</td>
                                        <td>
                                            <span class="badge bg-@(order.Status == "Pending" ? "warning" : order.Status == "Completed" ? "success" : "info")">
                                                @order.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">Geen recente bestellingen.</p>
                }
            </div>
        </div>
    </div>
</div>
