@page
@model IndexModel
@{
    ViewData["Title"] = "Matrix Inc - Mechanische Onderdelen";
}

<div class="hero-section text-center py-5 mb-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 10px;">
    <h1 class="display-3 fw-bold">Welkom bij Matrix Inc</h1>
    <p class="lead fs-4">Uw betrouwbare partner voor hoogwaardige mechanische onderdelen</p>
    <a asp-page="/Products/Index" class="btn btn-light btn-lg mt-3">Bekijk Producten</a>
</div>

<div class="mb-5">
    <h2 class="text-center mb-4"><i class="bi bi-star-fill text-warning"></i> Meest Verkocht</h2>
    <div class="row">
        @foreach (var product in Model.BestSellingProducts)
        {
            <div class="col-md-4 col-lg-2 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title">@product.Name</h6>
                        <p class="card-text small text-muted flex-grow-1">@product.Description</p>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="h5 mb-0 text-primary">€@product.Price.ToString("F2")</span>
                            </div>
                            <span class="badge bg-success small">@product.StockQuantity op voorraad</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="text-center mt-3">
        <a asp-page="/Products/Index" class="btn btn-outline-primary">Alle Producten <i class="bi bi-arrow-right"></i></a>
    </div>
</div>

<div class="row mb-5 pb-5">
    <div class="col-12">
        <h2 class="text-center mb-4">Onze Categorieën</h2>
    </div>
    @if (Model.Categories != null && Model.Categories.Any())
    {
        <div class="col-12 mb-5">
            <div class="d-flex flex-wrap justify-content-center gap-3">
                @foreach (var category in Model.Categories)
                {
                    <a asp-page="/Products/Index" asp-route-category="@category" class="btn btn-outline-primary btn-lg">
                        @category
                    </a>
                }
            </div>
        </div>
    }
</div>
