@page
@model MatrixInc.Web.Pages.OrderConfirmationModel
@{
    ViewData["Title"] = "Bestelling bevestigd";
}

<div class="text-center py-5">
    <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
    <h1 class="mt-4">Bedankt voor uw bestelling!</h1>
    <p class="lead">Uw bestelling is succesvol geplaatst.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Bestelling #@Model.OrderId</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-6">
                        <strong>Besteldatum:</strong><br />
                        @DateTime.Now.ToString("dd-MM-yyyy HH:mm")
                    </div>
                    <div class="col-6">
                        <strong>Status:</strong><br />
                        <span class="badge bg-warning">In behandeling</span>
                    </div>
                </div>

                <div class="mb-3">
                    <strong>Klantgegevens:</strong><br />
                    @Model.CustomerName<br />
                    @Model.CustomerEmail
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> 
                    <strong>@Model.OrderItemCount items</strong> besteld voor een totaal van 
                    <strong>€@Model.OrderTotal.ToString("F2")</strong>
                </div>

                <p class="text-muted small">
                    <i class="bi bi-envelope"></i> U ontvangt een bevestigingsmail op <strong>@Model.CustomerEmail</strong>
                </p>
            </div>
        </div>

        <div class="text-center mt-4 mb-5 pb-5">
            <a asp-page="/Products/Index" class="btn btn-primary btn-lg me-2">
                <i class="bi bi-shop"></i> Verder winkelen
            </a>
            <a asp-page="/Index" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-house"></i> Terug naar home
            </a>
        </div>
    </div>
</div>

