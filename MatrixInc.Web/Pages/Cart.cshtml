@page
@model MatrixInc.Web.Pages.CartModel
@{
    ViewData["Title"] = "Winkelwagen";
}

<h1 class="mb-4">
    <i class="bi bi-cart3"></i> Winkelwagen
</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.CartItems.Any())
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Prijs</th>
                            <th style="width: 150px;">Aantal</th>
                            <th>Totaal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            <tr>
                                <td>
                                    <strong>@item.ProductName</strong>
                                </td>
                                <td>€@item.Price.ToString("F2")</td>
                                <td>
                                    <form method="post" asp-page-handler="UpdateQuantity" class="d-inline">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <div class="input-group input-group-sm">
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control" />
                                            <button type="submit" class="btn btn-outline-secondary">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </div>
                                    </form>
                                </td>
                                <td><strong>€@item.TotalPrice.ToString("F2")</strong></td>
                                <td>
                                    <form method="post" asp-page-handler="Remove" class="d-inline">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end"><strong>Totaal:</strong></td>
                            <td colspan="2"><strong class="h4 text-primary">€@Model.Total.ToString("F2")</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <a asp-page="/Products/Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Verder winkelen
            </a>
        </div>
        <div class="col-md-6 text-end">
            <a asp-page="/Checkout" class="btn btn-primary btn-lg">
                Bestelling afronden <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Uw winkelwagen is leeg.
    </div>
    <a asp-page="/Products/Index" class="btn btn-primary">
        <i class="bi bi-shop"></i> Ga naar producten
    </a>
}
